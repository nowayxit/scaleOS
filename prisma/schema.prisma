generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER") // 'ADMIN', 'MANAGER', 'USER'
  
  accounts      Account[]
  sessions      Session[]
  
  agencyId      String?
  agency        Agency?   @relation(fields: [agencyId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ScaleOS Core Models

model Agency {
  id              String   @id @default(cuid())
  name            String
  plan            String   @default("agency") // 'solo', 'agency', 'enterprise'
  maxSeats        Int      @default(10)
  logoUrl         String?
  defaultRoutines String?
  
  users           User[]
  clients         Client[]
}

model Client {
  id              String   @id @default(cuid())
  name            String
  niche           String
  budget          Float
  currentSpend    Float
  targetCpa       Float
  currency        String   @default("BRL")
  healthStatus    String   @default("good") // 'good', 'warning', 'critical'
  avatarUrl       String?
  pendingInsight   String?  @db.Text
  lastOptimization String?
  
  // URLs
  adsManagerUrl   String?
  ga4Url          String?
  lookerUrl       String?
  driveFolderUrl  String?
  
  agencyId        String
  agency          Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  
  // Relations
  decisionLogs    DecisionLog[]
  creatives       Creative[]
  routines        Routine[]
  cases           ClientCase[]
  meetingNotes    MeetingNote[]
  tasks           Task[]
}

model DecisionLog {
  id         String   @id @default(cuid())
  date       DateTime @default(now())
  title      String
  hypothesis String
  result     String?
  type       String   @default("strategy") // 'strategy', 'creative', 'budget', 'pause'

  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Creative {
  id         String   @id @default(cuid())
  name       String
  type       String   @default("video") // 'video', 'static', 'ugc', 'carousel'
  hookRate   Float
  holdRate   Float
  ctr        Float
  roas       Float
  cpm        Float
  status     String   @default("active") // 'active', 'paused', 'fatigued'
  createdAt  DateTime @default(now())

  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientCase {
  id         String   @id @default(cuid())
  clientName String
  strategy   String
  investment Float
  revenue    Float    @default(0)
  roi        Float
  notes      String
  createdAt  DateTime @default(now())

  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
}

model MeetingNote {
  id         String   @id @default(cuid())
  date       DateTime @default(now())
  subject    String
  content    String

  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Routine {
  id         String   @id @default(cuid())
  label      String
  done       Boolean  @default(false)
  platform   String   @default("meta") // 'meta', 'google', 'geral'

  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model OptimizationSession {
  id               String   @id @default(cuid())
  date             DateTime @default(now())
  insight          String   @db.Text
  completedRoutines String?  @db.Text // Store JSON array of routine labels done in this session
  
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// Kanban Task Models

model Column {
  id    String @id @default(cuid())
  title String
  order Int    @default(0)
  tasks Task[]
}

model Tag {
  id    String @id @default(cuid())
  name  String
  color String
  tasks Task[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  priority    String    @default("medium") // 'low', 'medium', 'high'
  dueDate     String?
  createdAt   DateTime  @default(now())
  
  columnId    String
  column      Column    @relation(fields: [columnId], references: [id])
  
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  tags        Tag[]
}

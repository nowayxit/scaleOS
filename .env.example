# ===========================================
# ScaleOS — Environment Variables
# ===========================================
# Copie este arquivo para .env e preencha os valores

# URL do banco de dados PostgreSQL (fornecida pelo Railway ao criar o banco)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# URL pública do seu app (substituir pelo seu domínio no Railway)
NEXTAUTH_URL="https://seu-app.up.railway.app"

# Segredo do NextAuth — gere um aleatório em: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="sua-chave-secreta-aqui"
